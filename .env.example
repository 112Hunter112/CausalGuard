# No API key needed — CausalGuard uses Vertex AI via gcloud CLI credentials.
# Run: gcloud auth application-default login

# Vertex AI (required for LLM)
# Get project ID: gcloud config get-value project
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Optional: region (default: us-east5, supported for Claude Sonnet 4.6)
# VERTEX_REGION=us-east5
# Optional: Claude model — use short ID without @date (default: claude-sonnet-4-6).
# If you get 404: enable "Claude Sonnet 4.6" in Vertex AI → Model Garden, then accept terms.
# ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional: Gemini model for search / fallback (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# CausalGuard thresholds (tuned via calibrate.py)
LAYER1_ENABLED=true
LAYER2_ENABLED=true
LAYER3_ENABLED=true
LAYER2_KL_THRESHOLD=0.8
LAYER2_JSD_THRESHOLD=0.5
LAYER2_JACCARD_THRESHOLD=0.3
LAYER3_COSINE_THRESHOLD=0.75
LAYER2_WEIGHT=0.6
LAYER3_WEIGHT=0.4
LAYER4_ENABLED=true
LAYER5_ENABLED=true
LAYER5_THRESHOLD=0.15
